<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>60.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Weekly Timesheet</masterLabel>
    <description>Weekly/Monthly calendar view for Timesheet entry</description>
    
    <targets>
        <target>lightning__Tab</target>
        <target>lightning__RecordPage</target>
        <target>lightningCommunity__Page</target>
        <target>lightningCommunity__Default</target> 
    </targets>
    
    <targetConfigs>
        <!-- This section is CRITICAL for @api recordId and @api objectApiName to work on Record Pages -->
        <targetConfig targets="lightning__RecordPage">
            <property name="recordId" type="String" description="Record ID passed from the page" />
            <property name="objectApiName" type="String" description="Object API Name passed from the page" />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>